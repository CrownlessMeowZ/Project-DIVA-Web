<file path="frontend/src/index.css">
/* ================================================================
   PROJECT DIVA — FullWeb.css
   Design: Cyberpop Dark · Glassmorphism · Music-note Particles
   ================================================================ */

/* ---- TOKENS ---- */
:root {
    --bg:        #04040f;
    --surface:   #08081a;
    --card:      rgba(8, 8, 26, 0.72);
    --border:    rgba(0, 200, 255, 0.12);
    --border-h:  rgba(0, 212, 255, 0.50);
    --cyan:      #00d4ff;
    --pink:      #ff66cc;
    --gold:      #ffe566;
    --text:      #dde0ff;
    --muted:     #5e5e92;
    --topbar-h:  60px;
    --ff-d:      'Cinzel Decorative', serif;
    --ff-b:      'Rajdhani', sans-serif;
    --r:         12px;
    --t:         0.32s cubic-bezier(.4,0,.2,1);
}

/* ---- RESET ---- */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
    background: var(--bg);
    background-image:
        radial-gradient(ellipse 80% 50% at 20% 10%, rgba(0,212,255,.06) 0%, transparent 65%),
        radial-gradient(ellipse 60% 40% at 80% 90%, rgba(255,102,204,.06) 0%, transparent 65%);
    color: var(--text);
    font-family: var(--ff-b);
    font-size: 16px;
    line-height: 1.75;
    min-height: 100vh;
    overflow-x: hidden;
    padding-top: var(--topbar-h);
}
body#introduce { padding-top: 0; }

/* scrollbar */
::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--border-h); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--cyan); }
::selection { background: rgba(0,212,255,.22); }

/* ---- KEYFRAMES ---- */
@keyframes shimmer {
    from { background-position: -200% center; }
    to   { background-position:  200% center; }
}
@keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
}
@keyframes bounce {
    0%,100% { transform: translateX(-50%) translateY(0); }
    50%      { transform: translateX(-50%) translateY(8px); }
}
@keyframes pulse {
    0%,100% { box-shadow: 0 0 12px rgba(0,212,255,.10); }
    50%      { box-shadow: 0 0 30px rgba(0,212,255,.35); }
}
@keyframes scan {
    from { left: -200px; }
    to   { left: 110%; }
}

/* ---- SKIP LINK ---- */
.skip {
    position: absolute; top: -70px; left: 0; z-index: 3000;
    background: var(--cyan); color: #000; font-weight: 700;
    padding: 12px 20px; text-decoration: none;
    border-radius: 0 0 var(--r) 0; transition: top var(--t);
}
.skip:focus { top: 0; }

/* ================================================================
   TOPBAR — sticky global nav
   ================================================================ */
.topbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    height: var(--topbar-h);
    display: flex; align-items: center; gap: 16px;
    padding: 0 28px;
    background: rgba(4,4,15,.88);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    overflow: visible;
}

/* scan line animation on topbar */
.topbar::after {
    content: ''; position: absolute; top: 0; height: 100%;
    width: 200px;
    background: linear-gradient(90deg, transparent, rgba(0,212,255,.06), transparent);
    animation: scan 5s linear infinite;
    pointer-events: none;
    clip-path: inset(0);
}

.topbar-logo {
    font-family: var(--ff-d); font-size: 13px; letter-spacing: 3px;
    text-decoration: none; white-space: nowrap; flex-shrink: 0;
    background: linear-gradient(90deg, var(--cyan), var(--pink));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
    transition: filter var(--t);
}
.topbar-logo:hover { filter: brightness(1.2); }

.topbar-nav {
    display: flex; align-items: center; margin-left: auto; gap: 0;
}
.topbar-nav a {
    color: var(--muted); text-decoration: none; padding: 10px 14px;
    font-family: var(--ff-b); font-weight: 600; font-size: 12px;
    letter-spacing: 1.5px; text-transform: uppercase; position: relative;
    transition: color var(--t);
}
.topbar-nav a::after {
    content: ''; position: absolute; bottom: 0; left: 50%; right: 50%;
    height: 2px; background: var(--cyan);
    transition: left var(--t), right var(--t);
}
.topbar-nav a:hover { color: var(--cyan); }
.topbar-nav a:hover::after, .topbar-nav a.active::after {
    left: 0;
    right: 0;
}
/* Ensure uniform active indicator for ALL topbar nav links (including Series History) */
.topbar-nav a.active {
    color: var(--cyan);
}
.topbar-nav a.active::after {
    left: 0 !important;
    right: 0 !important;
}

/* ---- HAMBURGER ---- */
.hamburger {
    display: none; flex-direction: column; gap: 5px; cursor: pointer;
    background: none; border: 1px solid var(--border); border-radius: 8px;
    padding: 10px 12px; margin-left: auto;
    transition: border-color var(--t);
}
.hamburger:hover { border-color: var(--cyan); }
.hamburger span {
    display: block; width: 20px; height: 2px;
    background: var(--text); border-radius: 2px;
    transition: transform var(--t), opacity var(--t);
}
.hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ================================================================
   HERO SECTION — Introduce.html only
   ================================================================ */
.hero {
    position: relative; height: 100vh; min-height: 600px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; overflow: hidden;
    background:
        radial-gradient(ellipse 70% 60% at 50% 55%, rgba(0,212,255,.07) 0%, transparent 70%),
        radial-gradient(ellipse 40% 35% at 25% 80%, rgba(255,102,204,.06) 0%, transparent 70%),
        var(--bg);
}
#hero-canvas {
    position: absolute; inset: 0; width: 100%; height: 100%;
    pointer-events: none;
}
.hero-content {
    position: relative; z-index: 2; text-align: center;
    padding: 0 24px; animation: fadeUp 1s ease both;
}
.hero-eyebrow {
    font-size: 11px; letter-spacing: 5px; text-transform: uppercase;
    color: var(--cyan); opacity: .75; margin-bottom: 18px;
}
.hero-title {
    font-family: var(--ff-d);
    font-size: clamp(36px, 9vw, 88px);
    letter-spacing: 8px; line-height: 1.05;
    background: linear-gradient(90deg, var(--cyan) 0%, var(--pink) 40%, var(--gold) 70%, var(--cyan) 100%);
    background-size: 200% auto;
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    animation: shimmer 4s linear infinite;
    margin-bottom: 22px;
    filter: drop-shadow(0 0 32px rgba(0,212,255,.3));
}
.hero-sub {
    font-size: clamp(14px, 2vw, 18px); color: var(--muted);
    max-width: 500px; margin: 0 auto 28px; line-height: 1.8;
}

/* ── Hero Quick Links Bar ── */
.hero-quick-bar {
    display: flex; align-items: center; justify-content: center;
    flex-wrap: wrap; gap: 0;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 999px; padding: 6px 10px;
    margin: 0 auto 28px; width: fit-content; max-width: 90%;
}
.hql {
    position: relative; padding: 6px 16px;
    font-family: var(--ff-b); font-size: 11px;
    font-weight: 600; letter-spacing: 2px;
    text-transform: uppercase; text-decoration: none;
    color: rgba(255,255,255,0.4);
    transition: color var(--t);
    white-space: nowrap;
}
.hql::after {
    content: ''; position: absolute;
    bottom: 2px; left: 16px; right: 16px;
    height: 1.5px; transform: scaleX(0);
    transform-origin: left; transition: transform var(--t);
}
.hql:hover { color: #fff; }
.hql:hover::after { transform: scaleX(1); }

/* Per-page accent colors */
.hql-home  { color: var(--cyan); }
.hql-home::after  { background: var(--cyan); transform: scaleX(1); }
.hql-chars:hover  { color: var(--pink); }
.hql-chars::after { background: var(--pink); }
.hql-skin:hover   { color: var(--gold); }
.hql-skin::after  { background: var(--gold); }
.hql-ver:hover    { color: #aaffcc; }
.hql-ver::after   { background: #aaffcc; }
.hql-patch:hover  { color: #b388ff; }
.hql-patch::after { background: #b388ff; }
.hql-producers:hover  { color: #ffaa55; }
.hql-producers::after { background: #ffaa55; }
.hql-concerts:hover   { color: #00d4ff; }
.hql-concerts::after  { background: #00d4ff; }

/* Active page highlight — set via JS same as topbar */
.hql.active { color: #fff; }
.hql.active::after { transform: scaleX(1); }

.hql-sep {
    width: 1px; height: 12px;
    background: rgba(255,255,255,0.1); flex-shrink: 0;
}

.hero-cta { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

.btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 34px; background: var(--cyan); color: #000;
    font-family: var(--ff-b); font-weight: 700; font-size: 13px;
    letter-spacing: 2px; text-transform: uppercase; border-radius: 999px;
    text-decoration: none; border: none; cursor: pointer;
    transition: transform var(--t), box-shadow var(--t);
}
.btn-primary:hover {
    transform: translateY(-3px) scale(1.04);
    box-shadow: 0 10px 36px rgba(0,212,255,.42);
}
.btn-ghost {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 13px 34px; background: transparent; color: var(--text);
    font-family: var(--ff-b); font-weight: 600; font-size: 13px;
    letter-spacing: 2px; text-transform: uppercase; border-radius: 999px;
    text-decoration: none; border: 1px solid var(--border-h);
    transition: background var(--t), transform var(--t), box-shadow var(--t);
}
.btn-ghost:hover {
    background: rgba(0,212,255,.08); transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0,212,255,.18);
}
.scroll-hint {
    position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%);
    font-size: 10px; letter-spacing: 4px; text-transform: uppercase;
    color: var(--muted); display: flex; flex-direction: column; align-items: center; gap: 10px;
    animation: bounce 2.2s ease-in-out infinite;
}
.scroll-hint::after {
    content: ''; width: 1px; height: 36px;
    background: linear-gradient(180deg, var(--cyan), transparent);
}

/* ================================================================
   PAGE HERO — slim banner for inner pages
   ================================================================ */
.page-hero {
    border-bottom: 1px solid var(--border);
    padding: 52px 24px 40px; text-align: center;
    background: linear-gradient(180deg, rgba(0,212,255,.04) 0%, transparent 100%);
}
.page-hero-title {
    font-family: var(--ff-d); font-size: clamp(18px, 4vw, 34px);
    letter-spacing: 3px; margin-bottom: 12px;
    background: linear-gradient(90deg, var(--cyan), var(--pink));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.page-hero-sub { color: var(--muted); font-size: 15px; max-width: 600px; margin: 0 auto; }

/* ================================================================
   SHARED SECTION TITLES
   ================================================================ */
.section-title {
    font-family: var(--ff-d); font-size: clamp(14px, 2.6vw, 24px);
    color: var(--cyan); letter-spacing: 2px;
    margin: 36px 24px 16px; padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
    animation: fadeUp .8s ease both;
}
.center-title { text-align: center; border-bottom: none; margin: 36px auto 12px; max-width: 900px; }
.sub-text { color: var(--muted); font-size: 14px; text-align: center; margin-bottom: 24px; }

/* ================================================================
   GLASSMORPHISM CARDS
   ================================================================ */
.card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--r);
    padding: 22px 20px;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    position: relative; overflow: hidden;
    transition: transform var(--t), box-shadow var(--t), border-color var(--t);
    animation: fadeUp .7s ease both;
    display: flex;
    flex-direction: column;
}
.card figure {
    margin-top: auto;
    padding-top: 12px;
    overflow: hidden;
    border-radius: var(--r);
}
.card figure img { padding: 0; border-radius: var(--r); }
.card figure img:hover { transform: scale(1.04); box-shadow: none; filter: brightness(1.08); }

/* Portrait full-body images on home page */
.grid .card figure img {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center top;
    background: transparent;
    border: none;
}
/* Home card: min-height cho text để figure luôn bắt đầu ở cùng vị trí */
.grid .card p {
    min-height: 80px;
}
.card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0,212,255,.5), transparent);
    opacity: 0; transition: opacity var(--t);
}
.card:hover { transform: translateY(-6px); border-color: var(--border-h); }
.card:hover::before { opacity: 1; }
.card:hover { box-shadow: 0 18px 48px rgba(0,0,0,.55), 0 0 24px rgba(0,212,255,.12); }

/* stagger */
.grid .card:nth-child(1),.flex .card:nth-child(1){animation-delay:.05s}
.grid .card:nth-child(2),.flex .card:nth-child(2){animation-delay:.10s}
.grid .card:nth-child(3),.flex .card:nth-child(3){animation-delay:.15s}
.grid .card:nth-child(4),.flex .card:nth-child(4){animation-delay:.20s}
.grid .card:nth-child(5),.flex .card:nth-child(5){animation-delay:.25s}
.grid .card:nth-child(6){animation-delay:.30s}

.char-name { font-family: var(--ff-d); font-size: 13px; color: var(--accent-c, var(--pink)); letter-spacing: 1px; margin-bottom: 10px; text-align: center; }
.song-title { font-weight: 600; font-size: 17px; color: var(--gold); margin-bottom: 10px; }

/* ================================================================
   FLIP CARDS — Characters page
   ================================================================ */
.flip-hint {
    text-align: center; color: var(--muted); font-size: 13px;
    letter-spacing: 1px; padding: 4px 24px 0;
}
.char-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px; padding: 28px 24px;
    max-width: 1400px; margin: 0 auto;
}
.char-flip {
    perspective: 1000px; height: 480px; cursor: pointer;
}
.char-flip-inner {
    position: relative; width: 100%; height: 100%;
    transform-style: preserve-3d;
    transition: transform .7s cubic-bezier(.4,0,.2,1);
}
.char-flip:hover .char-flip-inner,
.char-flip.flipped .char-flip-inner { transform: rotateY(180deg); }

.char-flip-front, .char-flip-back {
    position: absolute; inset: 0;
    backface-visibility: hidden; -webkit-backface-visibility: hidden;
    border-radius: var(--r); overflow: hidden;
    border: 1px solid var(--border);
}
.char-flip-front { background: var(--surface); }
.char-flip-front img {
    width: 100%; height: 100%; object-fit: cover; object-position: center;
    display: block; border: none; padding: 0; border-radius: 0; margin: 0;
    transition: transform .7s ease;
    background: var(--surface);
}
.char-flip:hover .char-flip-front img { transform: scale(1.05); }

.char-name-overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 40px 16px 14px;
    background: linear-gradient(0deg, rgba(4,4,15,.95), transparent);
    font-family: var(--ff-d); font-size: 13px; letter-spacing: 2px;
    text-align: center; color: var(--text);
}
.char-flip-back {
    transform: rotateY(180deg);
    background: linear-gradient(135deg, #090920 0%, #0e0e2e 100%);
    padding: 22px 18px; display: flex; flex-direction: column; gap: 10px;
}
.char-back-name {
    font-family: var(--ff-d); font-size: 13px; letter-spacing: 2px;
    margin-bottom: 2px;
}
.char-code {
    font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--muted); margin-bottom: 4px;
}
.char-stat-row {
    display: flex; justify-content: space-between; align-items: flex-start;
    padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,.06);
    font-size: 13px;
}
.char-stat-label { color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 1px; }
.char-stat-val { color: var(--text); font-size: 13px; text-align: right; }
.char-songs-title {
    font-size: 10px; text-transform: uppercase; letter-spacing: 2px;
    color: var(--muted); margin-top: 4px;
}
.char-songs-list { list-style: none; display: flex; flex-direction: column; gap: 5px; }
.char-songs-list li {
    font-size: 12px; color: var(--text); padding: 4px 10px;
    background: rgba(0,212,255,.07); border-radius: 6px;
    border-left: 2px solid var(--accent-c, var(--cyan));
}

/* ================================================================
   PATCH NOTES — PatchNotes page
   ================================================================ */
.patch-timeline { max-width: 860px; margin: 0 auto; padding: 28px 24px 48px; }

.patch-entry {
    margin-bottom: 14px; border: 1px solid var(--border);
    border-radius: var(--r); overflow: hidden;
    background: var(--card); backdrop-filter: blur(8px);
    transition: border-color var(--t);
    animation: fadeUp .6s ease both;
}
.patch-entry:nth-child(1){animation-delay:.05s}
.patch-entry:nth-child(2){animation-delay:.10s}
.patch-entry:nth-child(3){animation-delay:.15s}
.patch-entry:nth-child(4){animation-delay:.20s}
.patch-entry:nth-child(5){animation-delay:.25s}
.patch-entry:nth-child(6){animation-delay:.30s}
.patch-entry:hover { border-color: rgba(0,212,255,.3); }
.patch-entry.open { border-color: rgba(0,212,255,.4); }

.patch-hdr {
    display: flex; align-items: center; gap: 12px;
    padding: 16px 20px; cursor: pointer; user-select: none;
    transition: background var(--t); flex-wrap: wrap;
}
.patch-hdr:hover { background: rgba(0,212,255,.03); }

.patch-version {
    font-family: var(--ff-d); font-size: 13px; color: var(--cyan);
    letter-spacing: 1px; min-width: 56px;
}
.patch-date { font-size: 12px; color: var(--muted); }
.patch-tags-g { display: flex; gap: 6px; flex-wrap: wrap; flex: 1; }

.tag {
    display: inline-block; font-size: 10px; font-weight: 700;
    letter-spacing: 1px; text-transform: uppercase;
    padding: 3px 10px; border-radius: 999px;
}
.tag-initial { background: rgba(160,100,255,.18); color: #cc88ff; }
.tag-content { background: rgba(0,212,255,.15); color: var(--cyan); }
.tag-fix     { background: rgba(255,102,204,.15); color: var(--pink); }
.tag-perf    { background: rgba(255,229,102,.15); color: var(--gold); }
.tag-qol     { background: rgba(100,220,120,.12); color: #88dd99; }
.tag-dlc     { background: rgba(255,160, 50,.12); color: #ffaa55; }

.patch-arrow {
    margin-left: auto; font-size: 11px; color: var(--muted); flex-shrink: 0;
    transition: transform var(--t);
}
.patch-entry.open .patch-arrow { transform: rotate(180deg); }

.patch-body { max-height: 0; overflow: hidden; transition: max-height .42s cubic-bezier(.4,0,.2,1); }
.patch-body-inner { padding: 0 20px 20px; border-top: 1px solid var(--border); }

.patch-section { margin-top: 16px; }
.patch-section-title {
    font-size: 10px; text-transform: uppercase; letter-spacing: 2px;
    color: var(--muted); margin-bottom: 10px;
    display: flex; align-items: center; gap: 10px;
}
.patch-section-title::after { content:''; flex:1; height:1px; background: var(--border); }
.patch-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.patch-list li {
    font-size: 14px; color: var(--text); padding-left: 20px;
    position: relative; line-height: 1.6;
}
.patch-list li::before {
    content: '▸'; position: absolute; left: 0; top: 3px;
    color: var(--cyan); font-size: 10px;
}
.patch-note {
    margin-top: 12px; padding: 10px 14px;
    background: rgba(255,229,102,.06); border-left: 2px solid var(--gold);
    border-radius: 0 var(--r) var(--r) 0;
    font-size: 13px; color: var(--muted); font-style: italic;
}

/* ================================================================
   IMAGES
   ================================================================ */
img {
    display: block; width: 100%; height: auto;
    border-radius: var(--r); border: 1.5px solid var(--cyan);
    padding: 3px; margin: 0 auto; background: var(--surface);
    transition: transform var(--t), box-shadow var(--t), filter var(--t);
}
img:hover { transform: scale(1.04); box-shadow: 0 0 28px rgba(0,212,255,.28); filter: brightness(1.08); }

.grid > .card:nth-child(odd)  img { border-color: var(--pink); }
.grid > .card:nth-child(even) img { border-color: var(--cyan); }
nav.links li:nth-child(odd)  img  { border-color: var(--gold); }
nav.links li:nth-child(even) img  { border-color: var(--pink); }

/* ---- video ---- */
video {
    width: 100%; height: auto; display: block;
    border-radius: var(--r); border: 1.5px solid var(--border); background: #000;
    transition: box-shadow var(--t);
}
video:hover { box-shadow: 0 0 22px rgba(0,212,255,.18); }

/* ---- figures ---- */
figure { text-align: center; margin-top: 16px; }
figcaption { font-size: 12px; color: var(--muted); margin-top: 8px; font-style: italic; }

/* ================================================================
   NAV LINKS (preview gallery)
   ================================================================ */
nav.links { display: block; width: 90%; margin: 12px auto 24px; }
nav.links ul {
    list-style: none; display: flex; flex-wrap: wrap;
    gap: 14px; justify-content: center; padding: 0; margin-top: 10px;
}
nav.links li { text-align: center; flex: 0 0 auto; }
nav.links li figcaption {
    font-size: 11px; color: var(--muted); margin-bottom: 6px;
    font-style: normal; font-weight: 600; letter-spacing: .5px; text-transform: uppercase;
}
nav.links img {
    width: 180px; height: 101px; object-fit: cover;
    animation: pulse 3s ease-in-out infinite;
}
nav.links img:focus { outline: 3px solid var(--pink); outline-offset: 4px; }

/* ---- preview box ---- */
.preview-wrapper { width: 66%; margin: 0 auto 12px; text-align: center; }
.preview-box {
    width: 100%; padding-top: 56.25%; height: 0;
    border: 2px dashed rgba(0,212,255,.35); border-radius: var(--r);
    background: rgba(0,212,255,.03);
    background-size: contain; background-position: center; background-repeat: no-repeat;
    transition: border-color var(--t), box-shadow var(--t);
}
.preview-box.active { border-style: solid; border-color: var(--pink); box-shadow: 0 0 32px rgba(255,102,204,.2); }
.preview-caption { margin-top: 8px; font-style: italic; font-weight: 600; color: var(--muted); font-size: 13px; min-height: 20px; }

/* ---- undo button ---- */
.undo-btn {
    display: block; margin: 0 auto 16px;
    padding: 8px 24px; background: transparent; color: var(--cyan);
    border: 1px solid var(--cyan); border-radius: 999px; cursor: pointer;
    font-family: var(--ff-b); font-size: 12px; font-weight: 600;
    letter-spacing: 2px; text-transform: uppercase;
    transition: background var(--t), color var(--t), transform var(--t);
}
.undo-btn:hover { background: var(--cyan); color: #000; transform: scale(1.05); }
.undo-btn:focus { outline: 3px solid var(--cyan); outline-offset: 3px; }

/* ================================================================
   GRID & FLEX LAYOUTS
   ================================================================ */
.grid {
    display: grid; grid-template-columns: 1fr;
    gap: 18px; padding: 20px 16px;
    max-width: 1400px; margin: 0 auto;
    grid-auto-rows: 1fr;
}
.flex {
    display: flex; flex-wrap: wrap; gap: 18px;
    padding: 20px 16px; justify-content: center;
    max-width: 1400px; margin: 0 auto;
}
.flex > .card { width: 100%; min-width: 280px; }

/* ================================================================
   ABOUT SECTION (Introduce page)
   ================================================================ */
.about-section {
    padding: 48px 24px 0;
    max-width: 900px; margin: 0 auto;
    text-align: center;
    animation: fadeUp .9s .1s ease both;
}
.about-text { color: var(--muted); font-size: 16px; line-height: 1.85; margin-bottom: 32px; }
.about-text strong { color: var(--cyan); }

/* ================================================================
   VERSION TIMELINE (VersionAndGameplay page)
   ================================================================ */
.version-timeline { max-width: 820px; margin: 0 auto; padding: 20px 24px; width: 100%; }
.timeline-list { list-style: none; padding: 0; position: relative; }
.timeline-list::before {
    content: ''; position: absolute; left: 52px; top: 0; bottom: 0; width: 2px;
    background: linear-gradient(180deg, var(--cyan), var(--pink)); opacity: .3;
}
.timeline-item {
    display: flex; gap: 22px; align-items: flex-start;
    margin-bottom: 26px; animation: fadeUp .7s ease both;
}
.timeline-item:nth-child(1){animation-delay:.05s}
.timeline-item:nth-child(2){animation-delay:.10s}
.timeline-item:nth-child(3){animation-delay:.15s}
.timeline-item:nth-child(4){animation-delay:.20s}
.timeline-item:nth-child(5){animation-delay:.25s}
.timeline-year {
    flex: 0 0 44px; font-family: var(--ff-d); font-size: 11px;
    color: var(--gold); text-align: right; padding-top: 5px; letter-spacing: 1px;
}
.timeline-body {
    flex: 1; background: var(--card); border: 1px solid var(--border);
    border-left: 3px solid var(--cyan); border-radius: var(--r); padding: 14px 18px;
    transition: border-left-color var(--t), box-shadow var(--t);
}
.timeline-body:hover { border-left-color: var(--pink); box-shadow: 0 0 20px rgba(255,102,204,.12); }
.timeline-body h3 { font-family: var(--ff-d); font-size: 12px; color: var(--cyan); margin-bottom: 6px; letter-spacing: 1px; }
.timeline-body p { color: var(--muted); font-size: 14px; line-height: 1.7; }

/* ================================================================
   FOOTER
   ================================================================ */
.site-footer { margin-top: 52px; border-top: 1px solid var(--border); padding: 22px 24px; background: var(--surface); }
.footer-inner {
    max-width: 1200px; margin: 0 auto;
    display: flex; flex-wrap: wrap; align-items: center;
    justify-content: space-between; gap: 12px;
    font-size: 13px; color: var(--muted);
}
.char-list summary { cursor: pointer; color: var(--cyan); font-weight: 600; list-style: none; font-size: 13px; }
.char-list[open] summary { color: var(--pink); }
.char-list nav { display: flex; flex-wrap: wrap; gap: 8px 16px; margin-top: 10px; }
.char-list nav a { color: var(--muted); text-decoration: none; font-size: 13px; transition: color var(--t); }
.char-list nav a:hover { color: var(--cyan); }

/* ================================================================
   MEDIA QUERY 1 — max-width: 479px (small mobile)
   ================================================================ */
@media screen and (max-width: 479px) {
    .topbar { padding: 0 16px; }
    .hamburger { display: flex; }
    .topbar-nav {
        position: absolute; top: var(--topbar-h); left: 0; right: 0;
        flex-direction: column; margin-left: 0; gap: 0;
        background: rgba(4,4,15,.96); backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border);
        max-height: 0; overflow: hidden;
        transition: max-height .4s cubic-bezier(.4,0,.2,1);
    }
    .topbar-nav.open { max-height: 320px; }
    .topbar-nav a {
        padding: 14px 20px; font-size: 13px; text-align: left;
        border-bottom: 1px solid var(--border); border-radius: 0;
    }
    .topbar-nav a::after { display: none; }
    .topbar-nav a.active,
    .topbar-nav a:hover { border-left: 3px solid var(--cyan); padding-left: 17px; }

    .hero-title { font-size: 32px; letter-spacing: 4px; }
    .hero-eyebrow { font-size: 9px; letter-spacing: 3px; }
    .hero-sub { font-size: 14px; }

    .grid { grid-template-columns: 1fr; padding: 12px 10px; gap: 14px; }
    .flex > .card { width: 100%; }
    .char-grid { grid-template-columns: 1fr 1fr; gap: 12px; padding: 16px 12px; }
    .char-flip { height: 320px; }

    .preview-wrapper { width: 95%; }
    nav.links img { width: 120px; height: 68px; }
    .section-title { font-size: 13px; }
    .patch-timeline { padding: 20px 12px; }
    .footer-inner { flex-direction: column; align-items: flex-start; }
}

/* ================================================================
   MEDIA QUERY 2 — 480px to 771px (large phones)
   ================================================================ */
@media screen and (min-width: 480px) and (max-width: 771px) {
    .hamburger { display: flex; }
    .topbar-nav {
        position: absolute; top: var(--topbar-h); left: 0; right: 0;
        flex-direction: column; margin-left: 0;
        background: rgba(4,4,15,.96); backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border);
        max-height: 0; overflow: hidden;
        transition: max-height .4s cubic-bezier(.4,0,.2,1);
    }
    .topbar-nav.open { max-height: 320px; }
    .topbar-nav a {
        padding: 13px 24px; border-bottom: 1px solid var(--border);
    }
    .topbar-nav a::after { display: none; }
    .topbar-nav a.active,
    .topbar-nav a:hover { border-left: 3px solid var(--cyan); padding-left: 21px; }

    .grid { grid-template-columns: 1fr 1fr; padding: 16px 14px; gap: 16px; }
    .flex > .card { width: calc(50% - 10px); min-width: 220px; }
    .char-grid { grid-template-columns: repeat(3, 1fr); gap: 14px; }
    .char-flip { height: 360px; }
    .preview-wrapper { width: 82%; }
    nav.links img { width: 148px; height: 83px; }
}

/* ================================================================
   MEDIA QUERY 3 — 772px to 997px (tablet)
   ================================================================ */
@media screen and (min-width: 772px) and (max-width: 997px) {
    .grid { grid-template-columns: 45vw 45vw; justify-content: center; gap: 22px; padding: 20px 14px; }
    .grid img { width: auto; max-width: 100%; max-height: 30vh; }
    .flex > .card { width: 45vw; min-width: 0; }
    .flex video { max-height: 30vh; }
    .char-grid { grid-template-columns: repeat(3, 1fr); gap: 18px; }
    .char-flip { height: 380px; }
    .preview-wrapper { width: 60%; }
    nav.links img { width: 160px; height: 90px; }
    .topbar-nav a { font-size: 11px; padding: 10px 10px; }
}

/* ================================================================
   MEDIA QUERY 4 — min-width: 998px (desktop)
   ================================================================ */
@media screen and (min-width: 998px) {
    .grid { grid-template-columns: repeat(3, 30vw); justify-content: center; gap: 28px; padding: 28px 20px; }
    .flex > .card { width: 30vw; min-width: 0; }
    .char-grid { grid-template-columns: repeat(3, 1fr); max-width: 1200px; }
    .char-grid--extra { max-width: 1200px; margin: 0 auto; }
    .char-flip { height: 420px; }
    .preview-wrapper { width: 50%; }
    nav.links img { width: 192px; height: 108px; }
    .about-text { font-size: 17px; }
    .card:hover { transform: translateY(-8px) rotateX(2deg); }
    .hero-title { filter: drop-shadow(0 0 40px rgba(0,212,255,.4)); }
}
/* ================================================================
   LIGHT MODE
   ================================================================ */
[data-theme="light"] {
    --bg:       #f0f4ff;
    --surface:  #e2e8f8;
    --card:     rgba(255,255,255,0.85);
    --border:   rgba(0,150,200,0.18);
    --border-h: rgba(0,150,200,0.55);
    --text:     #1a1a3a;
    --muted:    #6b7280;
}
[data-theme="light"] body {
    background-image:
        radial-gradient(ellipse 80% 50% at 20% 10%, rgba(0,180,220,.08) 0%, transparent 65%),
        radial-gradient(ellipse 60% 40% at 80% 90%, rgba(200,80,160,.07) 0%, transparent 65%);
}
[data-theme="light"] .topbar { background: rgba(235,240,255,.92); border-bottom-color: rgba(0,150,200,.2); }
[data-theme="light"] .topbar-logo { background: linear-gradient(90deg,#0080b0,#cc44aa); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
[data-theme="light"] .hero { background: linear-gradient(180deg,#dce8ff 0%,#f0f4ff 100%); }
[data-theme="light"] .hero-title { background: linear-gradient(90deg,#b8860b,#cc44aa,#007aaa); -webkit-background-clip:text; -webkit-text-fill-color:transparent; filter:none; }
[data-theme="light"] .page-hero { background: linear-gradient(160deg,#dce8ff 0%,#f0f4ff 100%); }
[data-theme="light"] .card { background: rgba(255,255,255,0.8); border-color: rgba(0,150,200,.2); }
[data-theme="light"] .patch-entry { background: rgba(255,255,255,.75); border-color: rgba(0,150,200,.18); }
[data-theme="light"] .patch-hdr { background: rgba(240,244,255,.9); }
[data-theme="light"] .patch-hdr:hover { background: rgba(220,232,255,.95); }
[data-theme="light"] .timeline-item { border-left-color: rgba(0,150,200,.3); }
[data-theme="light"] .timeline-year { color: #007aaa; }
[data-theme="light"] .filter-tab-btn.active {
    background: rgba(0,150,200,.12);
    border-color: #007aaa;
    color: #007aaa;
}
[data-theme="light"] ::-webkit-scrollbar-track { background: var(--bg); }
[data-theme="light"] ::-webkit-scrollbar-thumb { background: rgba(0,150,200,.4); }
[data-theme="light"] .hero-quick-bar { background: rgba(255,255,255,0.5); border-color: rgba(0,150,200,.2); }
[data-theme="light"] .hql { color: rgba(26,26,58,0.5); }
[data-theme="light"] .hql-sep { background: rgba(0,150,200,.2); }
[data-theme="light"] .btn-ghost { color: var(--text); border-color: rgba(0,150,200,.4); }
[data-theme="light"] .btn-ghost:hover { background: rgba(0,150,200,.1); }
[data-theme="light"] .char-flip-front, [data-theme="light"] .char-flip-back { background: rgba(255,255,255,.85); }
[data-theme="light"] .preview-box { border-color: rgba(0,150,200,.3); }
[data-theme="light"] .tag-initial  { background: rgba(140,80,220,.15); color: #7733bb; }
[data-theme="light"] .tag-content  { background: rgba(0,150,200,.15); color: #007aaa; }
[data-theme="light"] .tag-fix      { background: rgba(200,60,160,.15); color: #aa2288; }
[data-theme="light"] .tag-perf     { background: rgba(180,150,0,.15);  color: #8a7200; }
[data-theme="light"] .tag-platform { background: rgba(0,160,100,.12);  color: #007744; }
[data-theme="light"] .tag-qol      { background: rgba(0,160,80,.12);   color: #006633; }
[data-theme="light"] .topbar-nav.open { background: rgba(235,240,255,.97); }

/* ================================================================
   TOPBAR CONTROLS — theme + settings gộp vào hamburger area
   Trên desktop: hiện 2 icon bên phải topbar (trước hamburger)
   Trên mobile:  ẩn, thay bằng items trong menu dropdown
   ================================================================ */
.topbar-controls {
    display: flex; align-items: center; gap: 4px;
    flex-shrink: 0; position: relative;
}
.topbar-icon-btn {
    background: transparent; border: none;
    font-size: 18px; cursor: pointer; padding: 6px 8px;
    border-radius: 6px; line-height: 1;
    transition: transform 0.2s, background 0.2s;
    color: var(--text);
}
.topbar-icon-btn:hover { background: var(--border); }
#theme-toggle-btn:hover { transform: scale(1.2) rotate(20deg); }
#settings-open-btn:hover { transform: rotate(60deg); }

/* Mobile: ẩn inline controls, hiện trong dropdown */
@media screen and (max-width: 771px) {
    .topbar-controls { display: none; }
    .topbar-nav-settings {
        display: flex; flex-direction: column; gap: 0;
        border-top: 1px solid var(--border);
    }
    .nav-settings-row {
        display: flex; align-items: center; justify-content: space-between;
        padding: 12px 20px; border-bottom: 1px solid var(--border);
        font-family: var(--ff-b); font-size: 11px; letter-spacing: 2px;
        text-transform: uppercase; color: var(--muted);
    }
    .nav-settings-btns { display: flex; gap: 6px; }
    .nav-settings-opt {
        padding: 5px 14px; background: transparent;
        border: 1px solid var(--border); border-radius: 6px;
        font-family: var(--ff-b); font-size: 12px; font-weight: 600;
        color: var(--muted); cursor: pointer; transition: all 0.2s;
    }
    .nav-settings-opt.active { border-color: var(--cyan); color: var(--cyan); background: var(--border); }
    [data-theme="light"] .nav-settings-opt.active { border-color: #007aaa; color: #007aaa; background: rgba(0,150,200,.12); }
}
@media screen and (min-width: 772px) {
    .topbar-nav-settings { display: none; }
}

/* ================================================================
   SETTINGS PANEL — desktop slide-in drawer
   ================================================================ */
#settings-panel { pointer-events: none; }
#settings-panel.open { pointer-events: all; }
.settings-backdrop {
    position: fixed; inset: 0; z-index: 1200;
    background: rgba(0,0,0,0); transition: background 0.3s;
}
#settings-panel.open .settings-backdrop { background: rgba(0,0,0,0.45); }
.settings-drawer {
    position: fixed; top: 0; right: -300px; z-index: 1201;
    width: 260px; height: 100vh;
    background: var(--surface); border-left: 1px solid var(--border);
    transition: right 0.32s cubic-bezier(.4,0,.2,1);
    display: flex; flex-direction: column;
}
#settings-panel.open .settings-drawer { right: 0; }
.settings-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 20px 14px; border-bottom: 1px solid var(--border);
    font-family: var(--ff-d); font-size: 14px; letter-spacing: 2px;
    text-transform: uppercase; color: var(--cyan);
}
[data-theme="light"] .settings-header { color: #007aaa; }
.settings-close {
    background: none; border: none; color: var(--muted);
    font-size: 16px; cursor: pointer; padding: 4px 8px;
    border-radius: 4px; transition: color 0.2s, background 0.2s;
}
.settings-close:hover { color: var(--text); background: var(--border); }
.settings-body { padding: 20px; flex: 1; overflow-y: auto; }
.settings-group { margin-bottom: 28px; }
.settings-label {
    font-family: var(--ff-b); font-size: 11px; letter-spacing: 2px;
    text-transform: uppercase; color: var(--muted); margin-bottom: 12px;
}
.settings-row { display: flex; gap: 8px; }
.settings-theme-opt, .lang-opt {
    flex: 1; padding: 9px 0;
    background: transparent; border: 1px solid var(--border);
    border-radius: 8px; font-family: var(--ff-b); font-size: 13px;
    font-weight: 600; letter-spacing: 1px; color: var(--muted);
    cursor: pointer; transition: all 0.2s; text-align: center;
}
.settings-theme-opt:hover, .lang-opt:hover { border-color: var(--border-h); color: var(--text); }
.settings-theme-opt.active, .lang-opt.active {
    background: var(--border); border-color: var(--cyan); color: var(--cyan);
}
[data-theme="light"] .settings-theme-opt.active,
[data-theme="light"] .lang-opt.active { border-color: #007aaa; color: #007aaa; background: rgba(0,150,200,.12); }

/* ================================================================
   HERO QUICK BAR — fix overflow khi tiếng Việt
   ================================================================ */
.hero-quick-bar {
    flex-wrap: nowrap !important;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    white-space: nowrap;
    max-width: 92vw;
}
.hero-quick-bar::-webkit-scrollbar { display: none; }
.hql { white-space: nowrap; }
/* ================================================================
   FIX 1 — Page padding-top cho tất cả inner pages
   Home dùng hero full-screen nên không cần
   ================================================================ */
body:not(#introduce) {
    padding-top: var(--topbar-h);
}

/* ================================================================
   FIX 2 — Topbar controls: bỏ 2 icon rời, thay bằng
   một avatar button góc phải mở mini dropdown
   ================================================================ */
.topbar-controls {
    flex-shrink: 0;
    position: relative;
}

.topbar-avatar-btn {
    display: flex; align-items: center; gap: 8px;
    background: rgba(0,212,255,.07);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 5px 13px 5px 8px;
    cursor: pointer; color: var(--text);
    font-family: var(--ff-b); font-size: 11px;
    letter-spacing: 1.5px; text-transform: uppercase;
    transition: border-color var(--t), background var(--t);
    white-space: nowrap;
}
.topbar-avatar-btn:hover {
    border-color: var(--cyan);
    background: rgba(0,212,255,.12);
}
.topbar-avatar-icon {
    width: 26px; height: 26px; border-radius: 50%;
    background: linear-gradient(135deg, var(--cyan), var(--pink));
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; flex-shrink: 0;
    transition: transform var(--t);
}
.topbar-avatar-btn:hover .topbar-avatar-icon { transform: rotate(20deg); }
.topbar-avatar-label { line-height: 1; }

/* Mini dropdown */
.topbar-dropdown {
    position: absolute; top: calc(100% + 10px); right: 0;
    min-width: 200px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r);
    padding: 12px;
    box-shadow: 0 12px 40px rgba(0,0,0,.5);
    opacity: 0; transform: translateY(-6px) scale(0.97);
    pointer-events: none;
    transition: opacity 0.18s ease, transform 0.18s ease;
    z-index: 1100;
}
.topbar-dropdown.open {
    opacity: 1; transform: translateY(0) scale(1);
    pointer-events: all;
}
.topbar-dropdown-group { margin-bottom: 10px; }
.topbar-dropdown-group:last-child { margin-bottom: 0; }
.topbar-dropdown-label {
    font-size: 9px; letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--muted); margin-bottom: 6px; padding: 0 2px;
    font-family: var(--ff-b);
}
.topbar-dropdown-row { display: flex; gap: 6px; }
.topbar-dropdown-opt {
    flex: 1; padding: 7px 0; text-align: center;
    background: transparent; border: 1px solid var(--border);
    border-radius: 7px; font-family: var(--ff-b);
    font-size: 12px; font-weight: 600; letter-spacing: 0.5px;
    color: var(--muted); cursor: pointer;
    transition: all 0.15s;
}
.topbar-dropdown-opt:hover { border-color: var(--border-h); color: var(--text); }
.topbar-dropdown-opt.active { border-color: var(--cyan); color: var(--cyan); background: rgba(0,212,255,.08); }
[data-theme="light"] .topbar-dropdown-opt.active { border-color: #007aaa; color: #007aaa; background: rgba(0,150,200,.1); }
[data-theme="light"] .topbar-dropdown { background: rgba(235,240,255,.98); }

/* Divider between groups */
.topbar-dropdown-divider {
    height: 1px; background: var(--border); margin: 10px 0;
}

/* ================================================================
   FIX 3 — Page transition: fade + slide-up
   ================================================================ */
@keyframes pageEnter {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
}

.page-transition {
    animation: pageEnter 0.35s cubic-bezier(.22,1,.36,1) both;
}

/* ================================================================
   CHARACTERS — Tab filter bar + Extra badge
   ================================================================ */
.char-tab-bar {
    display: flex; gap: 8px; justify-content: center;
    padding: 0 24px 28px;
}
.char-tab-btn {
    padding: 10px 32px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-family: var(--ff-b); font-size: 11px;
    font-weight: 600; letter-spacing: 2px; text-transform: uppercase;
    color: var(--muted); cursor: pointer;
    transition: all 0.2s ease;
}
.char-tab-btn:hover {
    border-color: var(--cyan);
    color: var(--text);
}
.char-tab-btn.active {
    background: rgba(0,212,255,.1);
    border-color: var(--cyan);
    color: var(--cyan);
}

/* ================================================================
   GAME HISTORY — Filter tabs (Bước 3)
   Reuses visual language of .char-tab-bar for consistency
   ================================================================ */
.filter-tab-bar {
    display: flex;
    gap: 8px;
    justify-content: center;
    padding: 0 24px 24px;
    margin-top: 28px;
    margin-bottom: 8px;
}
.filter-tab-btn {
    padding: 9px 26px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-family: var(--ff-b);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.2s ease;
}
.filter-tab-btn:hover {
    border-color: var(--cyan);
    color: var(--text);
}
.filter-tab-btn.active {
    background: rgba(0,212,255,.12);
    border-color: var(--cyan);
    color: var(--cyan);
}
.filter-tab-btn.active:hover {
    background: rgba(0,212,255,.18);
}

.gh-filter-panel {
    max-width: 960px;
    margin: 0 auto 20px;
    padding: 0 24px;
}
.gh-filter-group {
    margin-bottom: 14px;
}
.gh-filter-label {
    display: block;
    font-family: var(--ff-b);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
}
.filter-chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}
.filter-chip {
    padding: 7px 16px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-family: var(--ff-b);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.5px;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.2s ease;
}
.filter-chip:hover {
    border-color: var(--cyan);
    color: var(--text);
}
.filter-chip.active {
    background: rgba(0,212,255,.1);
    border-color: var(--cyan);
    color: var(--cyan);
}
.gh-filter-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px 20px;
    padding-top: 4px;
}
.gh-filter-year {
    display: flex;
    align-items: center;
    gap: 10px;
}
.gh-filter-year .gh-filter-label {
    margin-bottom: 0;
}
.gh-year-select {
    padding: 7px 12px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-family: var(--ff-b);
    font-size: 12px;
    color: var(--text);
    cursor: pointer;
}
.gh-year-select:focus {
    outline: none;
    border-color: var(--cyan);
}
.gh-milestone-toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--ff-b);
    font-size: 11px;
    color: var(--muted);
    cursor: pointer;
    user-select: none;
}
.gh-milestone-toggle input {
    accent-color: var(--cyan);
}
.gh-filter-count {
    font-family: var(--ff-b);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.5px;
}
.gh-filter-clear {
    padding: 6px 14px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-family: var(--ff-b);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.2s ease;
}
.gh-filter-clear:hover {
    border-color: var(--cyan);
    color: var(--cyan);
}
.gh-filter-empty {
    text-align: center;
    padding: 40px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
}

/* Extra badge trên góc trên card */
.char-extra-badge {
    position: absolute; top: 12px; right: 12px;
    background: rgba(0,0,0,.65);
    border: 1px solid var(--accent-c, var(--cyan));
    color: var(--accent-c, var(--cyan));
    font-family: var(--ff-b); font-size: 9px;
    letter-spacing: 1.5px; text-transform: uppercase;
    padding: 3px 9px; border-radius: 999px;
    backdrop-filter: blur(6px);
    z-index: 2;
}

/* Description text mặt sau card */
.char-desc-back {
    font-size: 11px; color: var(--muted);
    line-height: 1.6; margin-top: 4px;
    border-top: 1px solid rgba(255,255,255,.06);
    padding-top: 8px;
}

/* object-position handled in base rule */

/* ================================================================
   PRODUCERS page (Bước 4)
   ================================================================ */
.producer-card {
  text-align: left;
  padding-bottom: 22px;
}
.producer-avatar-wrap {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 14px;
}
.producer-avatar {
  width: 108px;
  height: 108px;
  object-fit: cover;
  border-radius: 999px;
  border: 3px solid var(--accent-c, var(--cyan));
  padding: 4px;
  background: var(--surface);
}
.producer-avatar-wrap a {
  display: inline-block;
  border-radius: 999px;
  transition: transform 0.2s, box-shadow 0.2s;
}
.producer-avatar-wrap a:hover .producer-avatar {
  transform: scale(1.06);
  box-shadow: 0 0 0 3px var(--cyan);
}
.producer-name {
  font-family: var(--ff-d);
  font-size: 15px;
  color: var(--cyan);
  letter-spacing: 0.5px;
  margin-bottom: 4px;
  text-align: center;
}
.producer-meta {
  text-align: center;
  margin-bottom: 10px;
}
.producer-genre {
  font-size: 11px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--muted);
  background: rgba(0,212,255,.08);
  padding: 2px 10px;
  border-radius: 999px;
}
.producer-desc {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.55;
  margin-bottom: 12px;
}
.producer-famous {
  font-size: 12px;
  margin-bottom: 8px;
  padding-top: 8px;
  border-top: 1px dashed var(--border);
}
.producer-famous strong {
  display: block;
  color: var(--text);
  font-size: 14px;
  margin-top: 2px;
}
.producer-label {
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 1px;
  font-size: 10px;
}
.producer-songs {
  list-style: none;
  font-size: 12px;
  color: var(--muted);
  padding-left: 4px;
  margin: 0;
}
.producer-songs li {
  padding: 2px 0;
}
.producer-songs li::before {
  content: '♪ ';
  color: var(--cyan);
}

/* Concerts timeline — linked images (like Home character cards) */
.concert-figure {
  margin-top: 14px;
}

.concerts-timeline .timeline-body img {
  width: 100%;
  max-height: 220px;
  object-fit: cover;
  border: 2px solid var(--border);
  border-radius: var(--r);
  transition: border-color var(--t), transform var(--t);
}

.concerts-timeline .timeline-body a {
  display: block;
}

.concerts-timeline .timeline-body a:hover img {
  border-color: var(--pink);
  transform: translateY(-2px);
}

.concerts-timeline .timeline-body a:focus-visible img {
  outline: 3px solid var(--pink);
  outline-offset: 4px;
}

/* ================================================================
   CHARACTERS — Section labels (Crypton 6 / Extra)
   ================================================================ */
.chars-section-label {
    display: flex; align-items: center; gap: 16px;
    padding: 48px 32px 20px;
    max-width: 1400px; margin: 0 auto;
}
.chars-section-label span {
    font-family: var(--ff-b); font-size: 11px;
    letter-spacing: 3px; text-transform: uppercase;
    color: var(--cyan); white-space: nowrap;
}
.chars-section-label::after {
    content: ''; flex: 1; height: 1px;
    background: linear-gradient(90deg, var(--border), transparent);
}
.chars-section-label--extra {
    margin-top: 48px;
}
.chars-section-label--extra span { color: var(--pink); }
.chars-section-label--extra::after {
    background: linear-gradient(90deg, rgba(255,102,204,.3), transparent);
}

/* Extra grid — same size as Crypton 6 */
.char-grid--extra {
    max-width: 1200px;
    margin: 0 auto;
    padding: 28px 24px;
}

/* ================================================================
   SKIN SPOTLIGHT — Flip cards cho SkinAndSong page
   ================================================================ */
.skin-spotlight {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px 48px;
}
.skin-group {
    margin-bottom: 48px;
}
.skin-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    padding: 0 0 8px;
    max-width: 1200px;
    margin: 0 auto;
}
.skin-flip {
    perspective: 1000px;
    height: 480px;
    cursor: pointer;
}
.skin-flip-inner {
    position: relative; width: 100%; height: 100%;
    transform-style: preserve-3d;
    transition: transform .7s cubic-bezier(.4,0,.2,1);
}
.skin-flip:hover .skin-flip-inner,
.skin-flip.flipped .skin-flip-inner { transform: rotateY(180deg); }

.skin-flip-front, .skin-flip-back {
    position: absolute; inset: 0;
    backface-visibility: hidden; -webkit-backface-visibility: hidden;
    border-radius: var(--r); overflow: hidden;
    border: 1px solid rgba(255,255,255,.08);
}
.skin-flip-front { background: var(--surface); }
.skin-flip-front img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center top;
    display: block; border: none; padding: 0;
    border-radius: 0; margin: 0;
    transition: transform .7s ease;
    background: var(--surface);
}
.skin-flip:hover .skin-flip-front img { transform: scale(1.05); }

.skin-name-overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 40px 16px 14px;
    background: linear-gradient(0deg, rgba(4,4,15,.95), transparent);
    font-family: var(--ff-d); font-size: 12px; letter-spacing: 2px;
    text-align: center; color: var(--text);
}

.skin-flip-back {
    transform: rotateY(180deg);
    background: linear-gradient(135deg, #090920 0%, #0e0e2e 100%);
    padding: 24px 20px;
    display: flex; flex-direction: column; gap: 10px;
    border-color: var(--accent-c, var(--cyan));
}
.skin-back-name {
    font-family: var(--ff-d); font-size: 13px;
    letter-spacing: 2px; margin-bottom: 4px;
}
.skin-stat-row {
    display: flex; justify-content: space-between; align-items: flex-start;
    padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,.06);
    font-size: 13px;
}
.skin-stat-label {
    color: var(--muted); font-size: 10px;
    text-transform: uppercase; letter-spacing: 1px;
    flex-shrink: 0;
}
.skin-stat-val {
    color: var(--text); font-size: 13px;
    text-align: right; margin-left: 12px;
}
.skin-desc {
    font-size: 13px; color: var(--muted);
    line-height: 1.7; margin-top: 6px;
    border-top: 1px solid rgba(255,255,255,.06);
    padding-top: 10px;
    flex: 1;
    overflow-y: auto;
}

/* Responsive */
@media screen and (max-width: 479px) {
    .skin-grid { grid-template-columns: 1fr; }
    .skin-flip { height: 360px; }
}
@media screen and (min-width: 480px) and (max-width: 771px) {
    .skin-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .skin-flip { height: 380px; }
}
@media screen and (min-width: 772px) and (max-width: 997px) {
    .skin-grid { grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .skin-flip { height: 400px; }
}

/* Light mode */
[data-theme="light"] .skin-flip-back {
    background: linear-gradient(135deg, #e8eeff 0%, #f0f4ff 100%);
}
[data-theme="light"] .skin-flip-front,
[data-theme="light"] .skin-flip-back { border-color: rgba(0,150,200,.2); }

/* ── Spotlight → Gallery CTA ── */
.spotlight-gallery-cta {
    text-align: center;
    padding: 32px 0 16px;
}
.spotlight-gallery-link {
    display: inline-block;
    color: var(--cyan);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-decoration: none;
    border: 1px solid var(--cyan);
    border-radius: 999px;
    padding: 10px 28px;
    opacity: 0.85;
    transition: opacity .2s, background .2s, color .2s;
}
.spotlight-gallery-link:hover {
    opacity: 1;
    background: var(--cyan);
    color: #000;
}
[data-theme="light"] .spotlight-gallery-link {
    color: var(--cyan);
    border-color: var(--cyan);
}
[data-theme="light"] .spotlight-gallery-link:hover {
    background: var(--cyan);
    color: #fff;
}

/* ── Concert page extras ── */
.concert-meta {
    font-size: 13px;
    color: var(--muted);
    margin: 4px 0 10px;
    letter-spacing: 0.02em;
}
.concert-highlight {
    margin-top: 10px;
    padding: 8px 14px;
    border-left: 3px solid var(--cyan);
    background: rgba(0, 212, 255, 0.06);
    border-radius: 0 6px 6px 0;
    font-size: 13px;
    color: var(--cyan);
    font-style: italic;
}
[data-theme="light"] .concert-highlight {
    background: rgba(0, 150, 200, 0.08);
}

/* ================================================================
   GAME HISTORY — Filter tabs & game cards
   ================================================================ */
.gh-page {
  padding-bottom: 48px;
}

.gh-filter-section {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 24px 28px;
}

.gh-filter-group-label {
  display: block;
  font-family: var(--ff-b);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 8px;
}

.gh-filter-group + .gh-filter-group {
  margin-top: 14px;
}

.gh-filter-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.gh-filter-tab {
  padding: 9px 20px;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 999px;
  font-family: var(--ff-b);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--muted);
  cursor: pointer;
  transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
}

.gh-filter-tab:hover {
  border-color: var(--border-h);
  color: var(--text);
}

.gh-filter-tab.active {
  background: rgba(0, 212, 255, 0.12);
  border-color: var(--cyan);
  color: var(--cyan);
}

.gh-filter-meta {
  margin-top: 16px;
  font-family: var(--ff-b);
  font-size: 11px;
  color: var(--muted);
  letter-spacing: 0.5px;
}

.gh-card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 20px;
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 24px 40px;
}

.gh-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--r);
  overflow: hidden;
  transition: border-color var(--t), transform var(--t);
}

.gh-card:hover {
  border-color: var(--border-h);
  transform: translateY(-4px);
}

.gh-card-cover {
  aspect-ratio: 16 / 9;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.gh-card-cover a {
  display: block;
  width: 100%;
  height: 100%;
}

.gh-card-cover img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.25s ease;
}

.gh-card-cover a:hover img {
  transform: scale(1.03);
}

.gh-card-cover a:focus-visible img {
  outline: 3px solid var(--pink);
  outline-offset: -3px;
}

.gh-card-cover-placeholder {
  font-family: var(--ff-b);
  font-size: 11px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--muted);
  padding: 16px;
  text-align: center;
}

.gh-card-body {
  padding: 16px 18px 18px;
}

.gh-card-title {
  font-family: var(--ff-b);
  font-size: 14px;
  font-weight: 600;
  color: var(--text);
  line-height: 1.35;
  margin-bottom: 8px;
}

.gh-card-meta {
  font-size: 12px;
  color: var(--muted);
  margin-bottom: 10px;
}

.gh-card-series {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 999px;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  background: rgba(0, 212, 255, 0.12);
  color: var(--cyan);
  border: 1px solid var(--border);
}

.gh-empty {
  grid-column: 1 / -1;
  text-align: center;
  padding: 48px 16px;
  color: var(--muted);
  font-size: 14px;
}

@media (max-width: 480px) {
  .gh-filter-tabs {
    gap: 6px;
  }

  .gh-filter-tab {
    padding: 8px 14px;
    font-size: 10px;
  }

  .gh-card-grid {
    grid-template-columns: 1fr;
    padding: 0 16px 32px;
  }

  .gh-filter-section {
    padding: 0 16px 24px;
  }
}
